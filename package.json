{
  "name": "mingledb",
  "version": "1.1.0",
  "description": "Lightweight file based NoSQL DB",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.mjs",
      "default": "./index.js"
    }
  },
  "scripts": {
    "start": "node webtest.js",
    "test": "npm run test:unit && npm run test:interop",
    "test:unit": "jest tests/test.js",
    "test:interop": "npm run test:interop:cjs && npm run test:interop:esm && npm run test:interop:ts",
    "test:interop:cjs": "node tests/interop/commonjs.test.cjs",
    "test:interop:esm": "node tests/interop/esm.test.mjs",
    "test:interop:ts": "tsc -p tests/interop/tsconfig.json && node tests/interop/dist/typescript.test.js"
  },
  "keywords": [
    "database",
    "local",
    "bson",
    "compressed",
    "tinydb",
    "flatfile",
    "embedded"
  ],
  "author": "Cloud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mingledb/mingledb.git"
  },
  "type": "commonjs",
  "dependencies": {
    "bson": "^6.10.4",
    "mingledb": "^1.0.1"
  },
  "devDependencies": {
    "fastify": "^5.4.0",
    "jest": "^30.1.3",
    "typescript": "^6.0.2"
  }
}
