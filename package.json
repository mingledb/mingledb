{
  "name": "mingledb",
  "version": "1.0.4",
  "description": "Lightweight file based NoSQL DB",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json',JSON.stringify({type:'module'}))\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build",
    "test": "npm run build && jest",
    "test:coverage": "npm run build && jest --coverage"
  },
  "keywords": [
    "database",
    "local",
    "bson",
    "compressed",
    "tinydb",
    "flatfile",
    "embedded"
  ],
  "author": "Cloud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mingledb/mingledb.git"
  },
  "type": "commonjs",
  "dependencies": {
    "bson": "^6.10.4",
    "mingledb": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fastify": "^5.4.0",
    "jest": "^30.1.3",
    "typescript": "^5.8.3"
  }
}
